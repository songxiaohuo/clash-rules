AI = select, 美国-自动, 新加坡-自动, 台湾-自动, 日本-自动, 所有-手动
YouTube = select, 香港-自动, 台湾-自动, 美国-自动, 所有-手动
Netflix = select, 台湾-自动, 香港-自动, 所有-手动
TikTok = select, 日本-自动, 台湾-自动, 新加坡-自动, 所有-手动
流媒体 = select, 美国-自动, 台湾-自动, 香港-自动, 新加坡-自动, 所有-手动
Google = select, 香港-自动, 美国-自动, 台湾-自动, 日本-自动, 所有-手动, 直连
SEX = select, 香港-自动, 日本-自动, 美国-自动, 台湾-自动, 所有-手动, 直连
Microsoft = select, 直连, 香港-自动, 美国-自动, 台湾-自动, 新加坡-自动, 所有-手动
Apple = select, 直连, 香港-自动, 美国-自动, 台湾-自动, 所有-手动
Game = select, 直连, 香港-自动, 美国-自动, 台湾-自动, 所有-手动
国外 = select, 香港-自动, 美国-自动, 台湾-自动, 新加坡-自动, 日本-自动, 所有-手动, 直连
国内 = select, 直连, 所有-手动
🇬🇧 GiffGaff-英国优选 = url-test, 英国-自动, interval=300, tolerance=50
其他 = select, 国外, 直连

[Rule]
# === 1. 广告拦截 ===
RULE-SET,https://gh-proxy.com/raw.githubusercontent.com/songxiaohuo/clash-rules/main/list/Advertising_sr.list,拒绝
RULE-SET,https://gh-proxy.com/raw.githubusercontent.com/songxiaohuo/clash-rules/main/list/Privacy_sr.list,拒绝
RULE-SET,https://gh-proxy.com/raw.githubusercontent.com/songxiaohuo/clash-rules/main/list/Hijacking_sr.list,拒绝

# === 2. 个人置顶规则 ===
RULE-SET,https://raw.githubusercontent.com/songxiaohuo/clash-rules/main/list/song_color0.list,SEX
RULE-SET,https://raw.githubusercontent.com/songxiaohuo/clash-rules/main/list/song_cn0.list,国内
RULE-SET,https://raw.githubusercontent.com/songxiaohuo/clash-rules/main/list/song_global0.list,国外
DOMAIN-SUFFIX,giffgaff.com,🇬🇧 GiffGaff-英国优选
DOMAIN-KEYWORD,giffgaff,🇬🇧 GiffGaff-英国优选

# === 3. AI/影音/开发 ===
RULE-SET,https://gh-proxy.com/raw.githubusercontent.com/songxiaohuo/clash-rules/main/list/openai_sr.list,AI
RULE-SET,https://gh-proxy.com/raw.githubusercontent.com/songxiaohuo/clash-rules/main/list/perplexity_sr.list,AI
RULE-SET,https://gh-proxy.com/raw.githubusercontent.com/songxiaohuo/clash-rules/main/list/youtube_sr.list,YouTube
RULE-SET,https://gh-proxy.com/raw.githubusercontent.com/songxiaohuo/clash-rules/main/list/github_sr.list,国外
RULE-SET,https://gh-proxy.com/raw.githubusercontent.com/songxiaohuo/clash-rules/main/list/telegram_sr.list,国外
RULE-SET,https://gh-proxy.com/raw.githubusercontent.com/liandu2024/clash/refs/heads/main/list/Sex.list,SEX

# === 4. 兜底规则 ===
GEOIP,CN,国内
FINAL,其他

[Host]
localhost = 127.0.0.1